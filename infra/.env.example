# ═══════════════════════════════════════════════════════════════════════════════
# AI ORCHESTRA FOUNDATION — ENVIRONMENT CONFIGURATION
# Copy this file to .env before starting services:
# cp infra/.env.example infra/.env
# ═══════════════════════════════════════════════════════════════════════════════

# Docker Compose Profiles (Choose from: minimal | coding | business | full)
# minimal  - OmniRoute + Qdrant + Redis (RAM usage < 2GB)
# coding   - minimal + Ollama + Hermes Agent
# business - minimal + n8n + Hermes Agent (with gateway)
# full     - All services (RAM usage ~ 8GB, excluding LLM weights)
COMPOSE_PROFILES=minimal

# ── Service Port Mappings ─────────────────────────────────────────────────────
REDIS_PORT=6379
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
OMNI_PORT=20128
OMNI_API_PORT=20129
OLLAMA_PORT=11434
N8N_PORT=5678
HERMES_PORT=8080

# ── OmniRoute (LLM Gateway) Configuration ──────────────────────────────────────
# Generate secrets: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_min_48_chars_long_here
# Generate api key secret: openssl rand -hex 32
API_KEY_SECRET=your_api_key_secret_min_64_chars_here
INITIAL_PASSWORD=CHANGEME

# ── MCP Server Authentication ─────────────────────────────────────────────────
# Required for MCP HTTP/SSE transport
ORCH_MCP_API_KEY=orch_mcp_super_secret_api_key

# ── Ollama Local LLMs ─────────────────────────────────────────────────────────
# Comma-separated models to pre-pull / download on startup
OLLAMA_MODELS=hermes3,nomic-embed-text

# ── Hermes Agent Multi-Channel Gateway ────────────────────────────────────────
# Fill in credentials for active communication channels
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_BOT_TOKEN=
SIGNAL_BOT_TOKEN=

# ── Hermes Agent Email configuration
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
