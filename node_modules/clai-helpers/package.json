{
  "name": "clai-helpers",
  "version": "0.5.0",
  "description": "CLI tool that transpiles .claude/ AI config into GitHub Copilot, Gemini, and other AI tool formats",
  "type": "module",
  "bin": {
    "helpers": "./bin/helpers.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "validate": "tsc --noEmit",
    "prepublishOnly": "npm run validate && npm test && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "claude",
    "copilot",
    "gemini",
    "config",
    "sync",
    "cli"
  ],
  "license": "MIT",
  "author": "UnderUndre",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UnderUndre/ai.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/UnderUndre/ai/issues"
  },
  "homepage": "https://github.com/UnderUndre/ai/tree/main/packages/cli#readme",
  "dependencies": {
    "giget": "^2.0.0",
    "c12": "^2.0.0",
    "citty": "^0.1.0",
    "consola": "^3.0.0",
    "pathe": "^2.0.0",
    "defu": "^6.0.0",
    "@inquirer/prompts": "^7.0.0",
    "cli-table3": "^0.6.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
